class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
        int i=0;
        int j=0;
        while(i<arr.length-1){
            j=i+1;
            while(j<arr.length-1 && arr[i]==0 && arr[j]==0){
                j++;
            }
            if(arr[i]==0 && arr[j]!=0){
                int temp=arr[i];
                arr[i]=arr[j];
                arr[j]=temp;
            }
            i++;
        }
    }
}
